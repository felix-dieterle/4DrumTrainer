<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Microphone access for drum hit detection and rhythm analysis -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <!-- Vibration for haptic feedback on beat cues -->
    <uses-permission android:name="android.permission.VIBRATE" />
    <!-- Image picker for profile picture (API 33+) -->
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />
    <!-- Image picker for profile picture (API < 33) -->
    <uses-permission
        android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />
    <!-- Internet access for Nominatim geocoding and Overpass API (teacher search) -->
    <uses-permission android:name="android.permission.INTERNET" />
    <!-- Location for "use my current location" in teacher search -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />

    <uses-feature
        android:name="android.hardware.microphone"
        android:required="true" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.DrumTrainer">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:screenOrientation="portrait">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".ProfileActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:label="@string/title_profile" />

        <activity
            android:name=".LessonActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:label="@string/title_lesson" />

        <activity
            android:name=".ResultActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:label="@string/title_result" />

        <activity
            android:name=".CalibrationActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:label="@string/title_calibration" />

        <activity
            android:name=".ProfileRefinementActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:label="@string/title_profile_refinement" />

        <activity
            android:name=".TeacherSearchActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:label="@string/title_teacher_search" />

    </application>

</manifest>
