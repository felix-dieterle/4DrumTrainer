    <string name="level_0_title">Level 1 – Getting Started</string>
    <string name="level_0_desc">Learn to keep a steady beat on the hi-hat using quarter notes.</string>
    <string name="level_1_title">Level 2 – The Basic Beat</string>
    <string name="level_1_desc">Add bass drum on beats 1 &amp; 3 and snare on beats 2 &amp; 4.</string>
    <string name="level_2_title">Level 3 – Eighth-Note Hi-Hat</string>
    <string name="level_2_desc">Double up your hi-hat pattern to eighth notes for a groovier feel.</string>
    <string name="level_3_title">Level 4 – Open Hi-Hat</string>
    <string name="level_3_desc">Introduce the open hi-hat for extra expression.</string>
    <string name="level_4_title">Level 5 – Tom Fills</string>
    <string name="level_4_desc">Play your first single-stroke tom fill at the end of the bar.</string>
    <string name="level_5_title">Level 6 – Crash &amp; Ride</string>
    <string name="level_5_desc">Learn when to use the crash and ride cymbals.</string>
    <string name="level_6_title">Level 7 – Sixteenth Notes</string>
    <string name="level_6_desc">Speed up your hi-hat to sixteenth notes and add ghost notes.</string>
    <string name="level_7_title">Level 8 – Advanced Fills</string>
    <string name="level_7_desc">Master multi-tom fills and syncopated patterns.</string>

    <!-- Lesson titles and descriptions -->
    <string name="lesson_100_title">Hi-Hat Quarter Notes</string>
    <string name="lesson_100_desc">Strike the hi-hat once on each beat (1-2-3-4) at 60 BPM. Focus on keeping steady timing.</string>
    <string name="lesson_101_title">Hi-Hat Quarter Notes – Faster</string>
    <string name="lesson_101_desc">Same pattern, slightly faster. Keep the tempo steady from beat 1 to beat 4.</string>
    <string name="lesson_200_title">Basic Rock Beat</string>
    <string name="lesson_200_desc">Play bass drum on beats 1 &amp; 3, snare on beats 2 &amp; 4, and hi-hat on all 4 beats.</string>
    <string name="lesson_201_title">Basic Rock Beat – Faster</string>
    <string name="lesson_201_desc">Same pattern at a slightly higher tempo. Keep the groove solid.</string>
    <string name="lesson_300_title">Eighth-Note Hi-Hat</string>
    <string name="lesson_300_desc">Add hi-hat on the "and" of every beat (1-and-2-and-3-and-4-and).</string>
    <string name="lesson_301_title">Eighth-Note Hi-Hat – Faster</string>
    <string name="lesson_301_desc">Same eighth-note hi-hat pattern at a higher tempo.</string>
    <string name="lesson_400_title">Open Hi-Hat on 2 &amp; 4</string>
    <string name="lesson_400_desc">Open the hi-hat slightly on beats 2 &amp; 4 to give the pattern a backbeat feel.</string>
    <string name="lesson_500_title">Tom Fill on Beat 4</string>
    <string name="lesson_500_desc">Play the basic beat but replace the last two eighth notes with tom hits as a fill.</string>
    <string name="lesson_600_title">Ride Cymbal with Crash Accent</string>
    <string name="lesson_600_desc">Switch from hi-hat to ride cymbal and hit the crash on beat 1 at the top of each bar.</string>
    <string name="lesson_700_title">Sixteenth-Note Hi-Hat</string>
    <string name="lesson_700_desc">Play the hi-hat on every sixteenth note (4 hits per beat) with bass and snare underneath.</string>
    <string name="lesson_800_title">Advanced Four-Tom Fill</string>
    <string name="lesson_800_desc">Play three bars of sixteenth-note groove, then a four-note tom fill to finish the phrase.</string>
</resources>
