<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Instruction -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/refinement_instruction"
            android:textSize="15sp"
            android:layout_marginBottom="20dp" />

        <!-- Calibrated instruments card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            app:cardElevation="2dp"
            app:cardCornerRadius="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/refinement_calibrated_title"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/textCalibratedInstruments"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="13sp" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Round status -->
        <TextView
            android:id="@+id/textRoundStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="16sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="16dp" />

        <!-- Start / Stop round button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonStartRound"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/refinement_start_round"
            android:textSize="16sp"
            android:padding="14dp"
            android:layout_marginBottom="12dp" />

        <!-- Done button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonDone"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/refinement_done"
            android:padding="12dp"
            android:layout_marginBottom="24dp" />

        <!-- Completed rounds counter (hidden until first round finishes) -->
        <TextView
            android:id="@+id/textRoundCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:layout_marginBottom="8dp"
            android:visibility="gone" />

        <!-- Results section header (hidden until first hit) -->
        <TextView
            android:id="@+id/textResultsTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/refinement_results_title"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"
            android:visibility="gone" />

        <!-- Detection results (dynamically added in reverse-chronological order) -->
        <LinearLayout
            android:id="@+id/resultsContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />

    </LinearLayout>

</ScrollView>
